# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Europe/Berlin

# Database
# For Docker, set either Postgres or SQLITE_PATH. Default SQLite fallback is
# for local dev without Docker.
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=
SQLITE_PATH=

# Superuser bootstrap (Docker entrypoint)
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=

# Controller
CONTROLLER_INTERVAL_SECONDS=30
RELAY_POLL_INTERVAL_SECONDS=30
WEATHER_REFRESH_HOURS=6
WEATHER_LOOKBACK_DAYS=2
WEATHER_RETRY_MINUTES=60

# Site/Weather defaults
DEFAULT_SITE_NAME=Home
DEFAULT_SITE_LAT=50.1109
DEFAULT_SITE_LON=8.6821

# Modbus
MODBUS_DEFAULT_PORT=502
MODBUS_DEFAULT_UNIT_ID=1
RELAY_SIMULATOR=true
MODBUS_TIMEOUT_SECONDS=2.0
MODBUS_RETRIES=1
